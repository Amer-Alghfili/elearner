generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  email    String   @id @db.VarChar(255)
  password String?  @db.VarChar(255)
  learns   Learn[]

  @@map("users")
}

model Learn {
  id            Int               @id @default(autoincrement())
  title         String            @unique @db.VarChar(255)
  description   String?           @db.VarChar(255)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user_id       String
  user          User             @relation(fields: [user_id], references: [email])
  resources     Resource[]
  resourceTags  ResourceTag[]
  noteFiles     NoteFile[]
  notes         LearnNoteBlock[]
  flashCards    FlashCard[]
  practiceTasks PracticeTask[]

  @@map("learns")
}

model Resource {
  id             Int                              @id @default(autoincrement())
  title          String                           @db.VarChar(255)
  link           String?                          @db.VarChar(255)
  icon           String?                          @db.VarChar(255)
  parentResource Int?     @map("parent_resource") @db.Integer()
  tags           Json?                            @db.Json()
  learn_id       Int
  learn          Learn    @relation(fields: [learn_id], references: [id])
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt

  @@map("learns_resources")
}

model ResourceTag {
  id       Int     @id @default(autoincrement())
  label    String  @db.VarChar(255)
  color    String  @db.VarChar(255)
  learn_id Int
  learn    Learn  @relation(fields: [learn_id], references: [id])

  @@map("resource_tags")
}

model FlashCard {
  id         Int                          @id @default(autoincrement())
  stage      String                       @db.VarChar(255)
  due        DateTime
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
  learn_id   Int
  question   String                       @db.VarChar(255)
  answerType String   @map("answer_type") @db.VarChar(255)
  answer     String
  hint       String?                      @db.VarChar(255)
  options    Json?
  learn      Learn    @relation(fields: [learn_id], references: [id])

  @@map("learns_flash_cards")
}

model PracticeTask {
  id          Int       @id @default(autoincrement())
  learn_id    Int
  stage       String    @db.VarChar(255)
  due         DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  title       String    @db.VarChar(255)
  description String
  learn       Learn    @relation(fields: [learn_id], references: [id])

  @@map("learns_practice_tasks")
}

model NoteFile {
  id        Int              @id @default(autoincrement())
  title     String           @db.VarChar(255)
  emoji     String?          @db.VarChar(255)
  cover     String?          @db.VarChar(255)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  learn_id  Int
  learn     Learn           @relation(fields: [learn_id], references: [id])
  blocks    NoteFileBlock[]

  @@map("learns_note_files")
}

model NoteFileBlock {
  id        String    @id @db.VarChar(255)
  type      String    @db.VarChar(255)
  data      Json      @db.Json()
  order     Int
  updatedAt DateTime  @updatedAt
  file_id   Int
  file      NoteFile @relation(fields: [file_id], references: [id])

  @@map("learns_note_file_blocks")
}

model LearnNoteBlock {
  id        String    @id @db.VarChar(255)
  type      String    @db.VarChar(255)
  data      Json      @db.Json()
  order     Int
  updatedAt DateTime  @updatedAt
  learn_id  Int
  learn     Learn    @relation(fields: [learn_id], references: [id])

  @@map("learns_note_blocks")
}
