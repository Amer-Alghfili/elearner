generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  email    String   @id @db.VarChar(255)
  password String?  @db.VarChar(255)
  learns   Learn[]

  @@map("users")
}

model Learn {
  id             Int              @id @default(autoincrement())
  title          String           @unique @db.VarChar(255)
  description    String?          @db.VarChar(255)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user_id        String
  user           User            @relation(fields: [user_id], references: [email])
  todos          Todo[]
  resources      Resource[]
  resourceTags   ResourceTag[]
  knowledgeTests KnowledgeTest[]
  noteFiles      NoteFile[]

  @@map("learns")
}

model Todo {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  description String?  @db.VarChar(255)
  learn_id    Int
  learn       Learn   @relation(fields: [learn_id], references: [id])

  @@map("learns_todos")
}

model Resource {
  id                Int             @id @default(autoincrement())
  title             String          @db.VarChar(255)
  link              String          @db.VarChar(255)
  tags              Json?           @db.Json()
  learn_id          Int
  learn             Learn          @relation(fields: [learn_id], references: [id])
  knowledgeTest     KnowledgeTest? @relation(fields: [knowledge_test_id], references: [id])
  knowledge_test_id Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("learns_resources")
}

model ResourceTag {
  id       Int     @id @default(autoincrement())
  label    String  @db.VarChar(255)
  color    String  @db.VarChar(255)
  learn_id Int
  learn    Learn  @relation(fields: [learn_id], references: [id])

  @@map("resource_tags")
}

model KnowledgeTest {
  id          Int         @id @default(autoincrement())
  title       String      @db.VarChar(255)
  description String?     @db.VarChar(255)
  answer      String      @db.VarChar(255)
  hints       String?     @db.VarChar(255)
  stage       String      @db.VarChar(255)
  due         DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  resources   Resource[]
  learn_id    Int
  learn       Learn      @relation(fields: [learn_id], references: [id])

  @@map("learns_knowledge_tests")
}

model NoteFile {
  id        Int              @id @default(autoincrement())
  title     String           @db.VarChar(255)
  emoji     String?          @db.VarChar(255)
  cover     String?          @db.VarChar(255)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  learn_id  Int
  learn     Learn           @relation(fields: [learn_id], references: [id])
  blocks    NoteFileBlock[]

  @@map("learns_note_files")
}

model NoteFileBlock {
  id      String    @id @db.VarChar(255)
  type    String    @db.VarChar(255)
  data    Json      @db.Json()
  order   Int
  file_id Int
  file    NoteFile @relation(fields: [file_id], references: [id])

  @@map("learns_note_file_blocks")
}
